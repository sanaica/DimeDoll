# DimeDoll Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# OpenRouter API key (replaces Gemini + Anthropic)
OPENROUTER_API_KEY=

# MongoDB connection string
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=dimedoll

# Redis connection string
# Local: redis://localhost:6379/0
# Upstash: rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379/0
